# ============================================
# FencePro - Environment Variables Template
# ============================================
# Copia este archivo a .env.local o .env.aws
# y rellena con tus credenciales reales

# ===========================================
# OPCIÓN 1: MySQL Local (Desarrollo)
# ===========================================
# DB_URL=jdbc:mysql://localhost:3307/fencepro?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
# DB_USERNAME=root
# DB_PASSWORD=root

# ===========================================
# OPCIÓN 2: AWS RDS (Producción)
# ===========================================
# DB_URL=jdbc:mysql://tu-rds-endpoint.rds.amazonaws.com:3306/fencepro?useSSL=true&serverTimezone=UTC
# DB_USERNAME=admin
# DB_PASSWORD=tu_password_aws

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=genera-un-secret-aleatorio-largo-minimo-32-caracteres
JWT_EXPIRATION=60

# ===========================================
# Connection Pool (opcional)
# ===========================================
DB_POOL_SIZE=10
